{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "🚀 Debug Wallet API (localhost:3000)",
            "runtimeExecutable": "/Users/shinky777/.nvm/versions/node/v20.20.2/bin/node",
            "runtimeArgs": [
                "--require",
                "ts-node/register",
                "--require",
                "tsconfig-paths/register"
            ],
            "args": [
                "${workspaceFolder}/src/main.ts"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "PORT": "3000",
                "TS_NODE_PROJECT": "${workspaceFolder}/tsconfig.json"
            },
            "envFile": "${workspaceFolder}/.env",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ],
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ],
            "console": "integratedTerminal",
            "restart": true
        }
    ]
}